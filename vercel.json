{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/youtube/poll-playlist",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/youtube/fetch-transcripts",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/youtube/extract-knowledge",
      "schedule": "1-59/2 * * * *"
    },
    {
      "path": "/api/summaries/backfill?batch_size=10",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/meetings/process",
      "schedule": "*/2 * * * *"
    }
  ]
}
