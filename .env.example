# ============================================================
# Synapse V3 — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# ----------------------------------------------------------
# Supabase
# ----------------------------------------------------------
# Client-side (VITE_ prefix — exposed to browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (serverless functions)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------
# Google APIs
# ----------------------------------------------------------
# Client-side (VITE_ prefix — exposed to browser)
VITE_GEMINI_API_KEY=
VITE_YOUTUBE_API_KEY=

# Server-side only (serverless functions)
GEMINI_API_KEY=
YOUTUBE_API_KEY=

# ----------------------------------------------------------
# Third-party services (server-side only)
# ----------------------------------------------------------
APIFY_API_KEY=
RESEND_API_KEY=

# ----------------------------------------------------------
# Vercel / Infrastructure (server-side only)
# ----------------------------------------------------------
CRON_SECRET=
